# ---- Build Stage ----
FROM node:18-alpine AS builder

WORKDIR /app

# Use Nexus npm proxy to avoid SSL issues
RUN npm config set registry http://192.168.1.111:8081/repository/npm-proxy/ \
    && npm config set //192.168.1.111:8081/repository/npm-proxy/:_auth=$(echo -n 'admin:admin@123' | base64) \
    && npm config set strict-ssl false

# Copy workspace root files
COPY package.json package-lock.json* ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/

# Install dependencies
RUN npm ci --ignore-scripts

# Copy source code
COPY packages/shared/ packages/shared/
COPY apps/web/ apps/web/

# Build shared package then web
RUN npm run build -w packages/shared
RUN npm run build -w apps/web

# ---- Production Stage ----
FROM nginx:alpine

# Copy built SPA
COPY --from=builder /app/apps/web/dist/ /usr/share/nginx/html/

# Nginx config with API reverse proxy
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
