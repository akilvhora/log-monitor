# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (production / Docker)
DATABASE_URL="postgresql://postgres:admin@123@localhost:5432/logmonitor"

# SQLite (local dev without Docker)
# DATABASE_URL="file:./apps/api/prisma/dev.db"

# ── Anthropic AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-3-5-sonnet-20241022"
AI_MAX_LOGS_PER_SUMMARY=200

# ── API Server ───────────────────────────────────────────────────────────────
PORT=3001
API_KEY_SECRET="change-me-in-production"

# ── Log Retention ────────────────────────────────────────────────────────────
LOG_RETENTION_DAYS=30

# ── Docker Compose overrides ─────────────────────────────────────────────────
# POSTGRES_PASSWORD=changeme   # overrides the default in docker-compose.yml
